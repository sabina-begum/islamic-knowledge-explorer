{
  "name": "reflect-and-implement",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "author": {
    "name": "Reflect & Implement",
    "email": "begumsabina81193@gmail.com",
    "url": "https://reflectandimplement.com"
  },
  "license": "UNLICENSED",
  "copyright": "© 2024 Reflect & Implement. All rights reserved.",
  "description": "A comprehensive knowledge platform for reflection and implementation, featuring advanced search and visualization capabilities for meaningful content discovery.",
  "keywords": [
    "reflect",
    "implement",
    "knowledge",
    "data",
    "visualization",
    "search",
    "react",
    "typescript",
    "wisdom",
    "learning"
  ],
  "repository": {
    "type": "private",
    "url": "https://github.com/your-username/reflect-and-implement"
  },
  "homepage": "https://reflectandimplement.com",
  "scripts": {
    "dev": "vite",
    "build": "npm run optimize:images && tsc && vite build",
    "build:analyze": "npm run optimize:images && tsc && vite build --mode analyze",
    "build:fast": "tsc && vite build --mode production",
    "build:netlify": "tsc && vite build --mode production",
    "type-check": "tsc --noEmit",
    "optimize:images": "node scripts/optimize-images.js",
    "lint": "eslint src --max-warnings 250",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:security": "npm run test:headers && npm run test:csp && npm run test:validation",
    "test:headers": "node scripts/test-security-headers.js",
    "test:headers:quick": "node scripts/test-security.js",
    "test:server": "node test-server.js",
    "test:headers:local": "node test-server.js & timeout 2 && npm run test:headers:quick -- --url http://localhost:3001",
    "test:csp": "node scripts/test-csp-compliance.js",
    "test:validation": "vitest run --config vitest.security.config.ts",
    "security:audit": "npm audit --omit=dev && npm run test:security",
    "security:fix": "node scripts/fix-security-vulnerabilities.js",
    "security:update": "npm update && npm audit fix",
    "monitor": "node scripts/monitor-github.js",
    "monitor:setup": "echo 'Set GITHUB_TOKEN environment variable and update REPO_OWNER in monitor-github.js'"
  },
  "dependencies": {
    "@nivo/annotations": "0.99.0",
    "@nivo/arcs": "0.99.0",
    "@nivo/axes": "0.99.0",
    "@nivo/bar": "0.99.0",
    "@nivo/colors": "0.99.0",
    "@nivo/core": "0.99.0",
    "@nivo/geo": "0.99.0",
    "@nivo/legends": "0.99.0",
    "@nivo/line": "0.99.0",
    "@nivo/pie": "0.99.0",
    "@nivo/scales": "0.99.0",
    "@nivo/tooltip": "0.99.0",
    "@nivo/voronoi": "0.99.0",
    "date-fns": "^4.1.0",
    "firebase": "12.11.0",
    "jspdf": "^4.2.1",
    "lodash": "^4.17.23",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^7.13.1",
    "vite-node": "6.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/lodash": "^4.14.202",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "4.0.18",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.8",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.3.6",
    "terser": "5.46.1",
    "typescript": "^5.2.2",
    "vite": "8.0.3",
    "vite-bundle-analyzer": "^1.3.6",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "minimatch": ">=9.0.7"
  }
}
